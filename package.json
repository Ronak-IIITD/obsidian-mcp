  "version": "1.0.0",
  "description": "MCP server for Obsidian — save, search, and manage vault notes from any AI coding agent like OpenCode",
  "main": "dist/index.js",
  "bin": {
    "obsidian-mcp": "./dist/index.js"
  },
  "type": "module",
  "files": ["dist", "README.md"],
